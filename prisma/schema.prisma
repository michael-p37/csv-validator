// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UploadStatus {
  PENDING
  VALIDATED
  COMPLETED
}

//Usuarios del sisteme
model User {
  id        Int   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  age       Int?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  uploads   UploadJob[]
}

//proceso de carga
model UploadJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  uploadedBy  Int
  user        User     @relation(fields: [uploadedBy], references: [id])

  status      UploadStatus

  rows        UploadRow[]
}

//Filas temporales
model UploadRow {
  id          String @id @default(cuid())

  uploadJobId String
  uploadJob   UploadJob @relation(fields: [uploadJobId], references: [id])

  rowNumber   Int

  name        String?
  email       String?
  age         Int?

  isValid     Boolean @default(false)

  errors      Json?
}

//Datos a cargar
model Person {
  id        String @id @default(cuid())

  name      String
  email     String @unique
  age       Int

  createdAt DateTime @default(now())
}
